<mxfile host="65bd71144e">
    <diagram id="client-server-view-1" name="Client-Server View">
        <mxGraphModel dx="2033" dy="1075" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;font style=&quot;font-size: 42px;&quot;&gt;CodeReboot - Client-Server View&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;font style=&quot;font-size: 22px;&quot;&gt;The browser is the client; the Spring Boot app is the server. HTTP handles login and room setup, while WebSocket handles live gameplay updates.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=40;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="250" y="60" width="1300" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="client" value="&lt;font style=&quot;font-size: 26px;&quot;&gt;&lt;b&gt;Client Side&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;- login.html&lt;br&gt;- room.html&lt;br&gt;- game.html&lt;br&gt;- app.css&lt;br&gt;- JS modules in src/main/resources/static/js&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="120" y="250" width="520" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="server" value="&lt;font style=&quot;font-size: 26px;&quot;&gt;&lt;b&gt;Server Side&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;- AuthController / RoomController / SystemController&lt;br&gt;- GameSocketHandler / GameSocketCommandDispatcher&lt;br&gt;- AuthService / RoomService / GameSimulationService&lt;br&gt;- SecurityConfig / JwtAuthenticationFilter&lt;br&gt;- PostgreSQL + in-memory room state&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=15;" parent="1" vertex="1">
                    <mxGeometry x="1040" y="250" width="620" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="browserNote" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;User interaction starts in the browser.&lt;br&gt;Static assets are served once, then the client keeps talking to the server.&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="150" y="600" width="500" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="protocolNote" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;HTTP request/response for auth and room APIs.&lt;br&gt;WebSocket for live room state and match events.&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="600" width="635" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="e1" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;HTTP: register, login, create/join room&lt;/font&gt;" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=14;" parent="1" source="client" target="server" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e2" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;WebSocket: ready, move, fire, broadcast state&lt;/font&gt;" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;align=center;" parent="1" source="server" target="client" edge="1">
                    <mxGeometry x="0.005" y="-28" relative="1" as="geometry">
                        <mxPoint x="-1" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e3" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;serves static pages&lt;/font&gt;" style="endArrow=block;html=1;dashed=1;strokeWidth=2;fontSize=14;entryX=1;entryY=0.75;entryDx=0;entryDy=0;exitX=0;exitY=0.75;exitDx=0;exitDy=0;" parent="1" source="server" target="client" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1040" y="522" as="sourcePoint"/>
                        <mxPoint x="640" y="522" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="legend" value="&lt;font style=&quot;font-size: 28px;&quot;&gt;This is a classic client-server split: the browser owns presentation and user input, while the server owns auth, game rules, and authoritative state.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=20;" parent="1" vertex="1">
                    <mxGeometry x="170" y="790" width="1460" height="72" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>