<mxfile host="app.diagrams.net">
  <diagram id="client-server-view-1" name="Client-Server View">
    <mxGraphModel dx="1601" dy="1019" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=40;fontStyle=1;" value="&lt;font style=&quot;line-height: 100%; font-size: 50px;&quot;&gt;CodeReboot - Client-Server View&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-weight: 400;&quot;&gt;&lt;font style=&quot;font-size: 22px;&quot;&gt;The browser is the client; the Spring Boot app is the server. HTTP handles login and room setup, while WebSocket handles live gameplay updates.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="1300" x="250" y="60" as="geometry" />
        </mxCell>
        <mxCell id="client" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=15;" value="&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Client Side&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;- login.html&lt;br&gt;- room.html&lt;br&gt;- game.html&lt;br&gt;- app.css&lt;br&gt;- JS modules in src/main/resources/static/js&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="520" x="120" y="250" as="geometry" />
        </mxCell>
        <mxCell id="server" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=15;" value="&lt;font style=&quot;font-size: 30px;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;Server Side&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;- AuthController / RoomController / SystemController&lt;br&gt;- GameSocketHandler / GameSocketCommandDispatcher&lt;br&gt;- AuthService / RoomService / GameSimulationService&lt;br&gt;- SecurityConfig / JwtAuthenticationFilter&lt;br&gt;- PostgreSQL + in-memory room state&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="620" x="1040" y="250" as="geometry" />
        </mxCell>
        <mxCell id="browserNote" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;User interaction starts in the browser.&lt;br&gt;Static assets are served once, then the client keeps talking to the server.&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="500" x="150" y="600" as="geometry" />
        </mxCell>
        <mxCell id="protocolNote" parent="1" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" value="&lt;font style=&quot;font-size: 24px;&quot;&gt;HTTP request/response for auth and room APIs.&lt;br&gt;WebSocket for live room state and match events.&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="635" x="1030" y="600" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="client" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=14;" target="server" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;HTTP: register, login, create/join room&lt;/font&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="server" style="endArrow=block;html=1;rounded=0;strokeWidth=2;fontSize=14;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;align=center;" target="client" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;WebSocket: ready, move, fire, broadcast state&lt;/font&gt;">
          <mxGeometry relative="1" x="0.005" y="-28" as="geometry">
            <mxPoint x="-1" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="server" style="endArrow=block;html=1;dashed=1;strokeWidth=2;fontSize=14;entryX=1;entryY=0.75;entryDx=0;entryDy=0;exitX=0;exitY=0.75;exitDx=0;exitDy=0;" target="client" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;serves static pages&lt;/font&gt;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="522" as="sourcePoint" />
            <mxPoint x="640" y="522" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=20;" value="&lt;font style=&quot;font-size: 28px;&quot;&gt;This is a classic client-server split: the browser owns presentation and user input, while the server owns auth, game rules, and authoritative state.&lt;/font&gt;" vertex="1">
          <mxGeometry height="72" width="1559" x="112" y="783" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
