    <diagram id="cc-view-extension-v2" name="C and C View - Feature Extension Flow">
        <mxGraphModel dx="1201" dy="764" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=40;fontStyle=1;" value="CodeReboot - Feature Extension Flow" vertex="1">
                    <mxGeometry x="70" y="42" width="860" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;" value="Use this page to explain exactly where new features are added without creating cross-layer coupling." vertex="1">
                    <mxGeometry x="70" y="92" width="1400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="lane1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;" value="&lt;b&gt;1) Entry Point&lt;/b&gt;&lt;br&gt;&lt;br&gt;REST: add endpoint in controller&lt;br&gt;WS: add command in dispatcher" vertex="1">
                    <mxGeometry x="100" y="220" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="lane2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;" value="&lt;b&gt;2) Security&lt;/b&gt;&lt;br&gt;&lt;br&gt;JWT and auth remain in filters/config.&lt;br&gt;Do not put auth in domain entities." vertex="1">
                    <mxGeometry x="440" y="220" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="lane3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;" value="&lt;b&gt;3) Application Use-Case&lt;/b&gt;&lt;br&gt;&lt;br&gt;Implement orchestration in service&lt;br&gt;(primarily RoomService)." vertex="1">
                    <mxGeometry x="780" y="220" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="lane4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" value="&lt;b&gt;4) Domain Rules&lt;/b&gt;&lt;br&gt;&lt;br&gt;Extend Room/lifecycle/trackers.&lt;br&gt;Keep rules deterministic and testable." vertex="1">
                    <mxGeometry x="1120" y="220" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="lane5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=16;" value="&lt;b&gt;5) Side Effects&lt;/b&gt;&lt;br&gt;&lt;br&gt;Persist if needed, then broadcast&lt;br&gt;through WebSocketRoomBroadcaster." vertex="1">
                    <mxGeometry x="1460" y="220" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="f1" edge="1" parent="1" source="lane1" target="lane2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;fontSize=14;" value="validated request">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f2" edge="1" parent="1" source="lane2" target="lane3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;fontSize=14;" value="authorized">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f3" edge="1" parent="1" source="lane3" target="lane4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;fontSize=14;" value="business command">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f4" edge="1" parent="1" source="lane4" target="lane5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;fontSize=14;" value="state updated">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="good" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;" value="&lt;b&gt;Healthy change pattern&lt;/b&gt;&lt;br&gt;entrypoint -&gt; service use-case -&gt; domain update -&gt; broadcast" vertex="1">
                    <mxGeometry x="460" y="520" width="940" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="risk1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" value="&lt;b&gt;Avoid&lt;/b&gt;: business rules in controllers or socket handlers" vertex="1">
                    <mxGeometry x="220" y="720" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="risk2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" value="&lt;b&gt;Avoid&lt;/b&gt;: duplicating validation across REST and WS" vertex="1">
                    <mxGeometry x="700" y="720" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="risk3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" value="&lt;b&gt;Avoid&lt;/b&gt;: growing RoomService without extracting sub-use-cases" vertex="1">
                    <mxGeometry x="1180" y="720" width="420" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="note2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=20;" value="Presentation script: show top row for architecture path, then use red boxes to justify maintainability guardrails." vertex="1">
                    <mxGeometry x="70" y="1030" width="1680" height="60" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
